APP_NAME=Data Creator Hub
APP_SESSION_SECRET=change-this-to-a-long-random-secret

# Admin login
ADMIN_USERNAME=john
ADMIN_PASSWORD=jon6y.crae
ADMIN_EMAILS=you@gmail.com

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=data_creator_hub
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_SSL_CA=
MYSQL_SSL_DISABLED=true
MYSQL_CONNECT_TIMEOUT=10

# Optional DB_* aliases (same values, kept for compatibility)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=data_creator_hub
DB_USER=root
DB_PASSWORD=change_me

# Google OAuth (for update signups)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8501

# GitHub PAT uploads
USE_GITHUB_UPLOAD=true
GITHUB_TOKEN=
GITHUB_REPO=your-username/your-repo
GITHUB_BRANCH=main
GITHUB_UPLOAD_DIR=resources
